{
  "name": "easysubmit",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0 <26"
  },
  "scripts": {
    "dev": "node scripts/run.mjs dev",
    "dev:fast": "node scripts/run.mjs dev --fast",
    "dev:next": "next dev",
    "predev:next": "node scripts/clear-next-for-dev.mjs",
    "dev:clean": "rm -rf .next && next dev",
    "deploy:prod": "node scripts/run.mjs deploy:prod",
    "build": "prisma generate && NODE_OPTIONS=--max-old-space-size=8192 next build",
    "vercel-build": "prisma generate && node scripts/prisma-migrate-deploy.mjs && node scripts/validate-analytics-env.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "easy": "node scripts/run.mjs dev",
    "easy:prod": "node scripts/run.mjs deploy:prod",
    "db:check": "node scripts/validate-database-url.mjs",
    "env:whoami": "node scripts/env-whoami.mjs",
    "env:repair-local": "node scripts/repair-local-env.mjs",
    "postinstall": "prisma generate",
    "validate:ats-template": "npx --yes tsx scripts/validate-ats-template.ts",
    "validate:bhagath-sample": "npx --yes tsx scripts/validate-bhagath-sample.ts",
    "test": "NODE_OPTIONS=--max-old-space-size=4096 vitest run --config config/vitest.config.ts",
    "test:coverage": "vitest run --config config/vitest.config.ts --coverage",
    "test:components": "vitest run --config config/vitest.component.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "build:extension": "node scripts/build-extension.mjs",
    "build:extension:store": "EXTENSION_STORE_BUILD=1 node scripts/build-extension.mjs",
    "pack:extension:crx": "node scripts/pack-extension-crx.mjs",
    "package:extension:store": "npm run build:extension:store && npm run pack:extension:crx",
    "build:extensions": "node scripts/build-extensions.mjs",
    "extension:detect-eval": "npx tsx scripts/extension-detect-eval.ts",
    "db:migrate": "node scripts/prisma-migrate-deploy.mjs",
    "db:migrate:dev": "prisma migrate dev",
    "prod:health": "node scripts/run.mjs admin -- node scripts/prod-health-check.mjs",
    "prod:verify-posthog": "node scripts/verify-prod-posthog-live.mjs",
    "vercel:sync-analytics": "node scripts/sync-vercel-analytics-env.mjs",
    "prod:repair-analytics": "node scripts/repair-prod-analytics.mjs",
    "prod:ensure-avatars-bucket": "node scripts/run.mjs admin -- node scripts/ensure-avatars-bucket.mjs",
    "prod:repair": "node scripts/prod-repair.mjs",
    "prod:deploy": "node scripts/run.mjs deploy:prod",
    "db:seed": "prisma db seed",
    "db:import-system-keys": "npx --yes tsx scripts/import-system-keys-to-vault.ts",
    "pool:status": "npx --yes tsx scripts/pool-status.ts",
    "pool:reset": "npx --yes tsx scripts/pool-reset-dev.ts",
    "ai:usage": "npx --yes tsx scripts/ai-usage-stats.ts",
    "analytics:setup": "node scripts/posthog-setup-dashboards.mjs",
    "posthog:journey": "npx tsx scripts/posthog-journey-report.ts",
    "enhance:trace": "npx tsx scripts/enhance-trace-report.ts",
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/openai": "^3.0.73",
    "@google/generative-ai": "^0.24.1",
    "@headlessui/react": "^2.2.10",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "ai": "^6.0.208",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "docx-to-pdf-wasm": "^0.1.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^1.18.0",
    "mammoth": "^1.12.0",
    "next": "^14.2.29",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "posthog-js": "^1.395.0",
    "rake-js": "^0.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.79.0",
    "react-resizable-panels": "^2.1.9",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.287",
    "@types/node": "^20.17.50",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.6",
    "chrome-webstore-upload": "^6.0.0",
    "crx3": "^2.0.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "linkedom": "^0.18.12",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.3",
    "prisma": "^7.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
