# QA project region: us-east-1 (pooler host aws-1-us-east-1)
DATABASE_URL=postgresql://postgres.dwccqrbpwbnuoiihpgth:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
