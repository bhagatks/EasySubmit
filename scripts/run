#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

cmd="${1:-}"
sub="${2:-}"

case "$cmd" in
  easy)
    case "$sub" in
      prod|production)
        exec node "$ROOT/scripts/run.mjs" deploy:prod
        ;;
      "")
        exec node "$ROOT/scripts/run.mjs" dev
        ;;
      *)
        echo "Unknown target: $sub" >&2
        echo "Usage: run easy [prod]" >&2
        exit 1
        ;;
    esac
    ;;
  *)
    echo "Usage: run easy [prod]" >&2
    echo "" >&2
    echo "  run easy       Local dev (.env.local, injected)" >&2
    echo "  run easy prod  Deploy to Vercel (dashboard secrets)" >&2
    exit 1
    ;;
esac
