#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

cmd="${1:-}"
sub="${2:-}"

case "$cmd" in
  easy)
    case "$sub" in
      prod|production)
        exec bash "$ROOT/scripts/easy-prod.sh"
        ;;
      "")
        exec bash "$ROOT/scripts/easy-dev.sh"
        ;;
      *)
        echo "Unknown target: $sub" >&2
        echo "Usage: run easy [prod]" >&2
        exit 1
        ;;
    esac
    ;;
  *)
    echo "Usage: run easy [prod]" >&2
    echo "" >&2
    echo "  run easy       Local dev (.env.local)" >&2
    echo "  run easy prod  Deploy to Vercel (prod env from Vercel only)" >&2
    exit 1
    ;;
esac
