generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ResumeProfilePickerMode {
  DEFAULT
  LAST_SELECTED
}

model User {
  id               String         @id @default(cuid())
  firstName        String?
  lastName         String?
  name             String?
  email            String?        @unique
  emailVerified    DateTime?
  image            String?
  onboardingStep   Int            @default(0)
  lastAuthProvider String?
  /// Pointer to `vault.secrets.id` for the active BYOK key — never store raw secrets here.
  vaultKeyId       String?        @db.Uuid
  /// Active BYOK provider (e.g. `anthropic`, `openai`, `gemini`).
  activeProvider   String?
  /// `auto` | `customer` | `system` — which AI key powers enhance flows.
  aiSourcePreference String       @default("auto")
  aiEnhancementsToday Int         @default(0)
  aiCallsToday        Int         @default(0)
  aiQuotaResetAt      DateTime    @default(now())
  /// Deprecated — use `app_config.aiEngine.quotas.customer.aiDailyUnlimited`.
  aiDailyUnlimited    Boolean     @default(false)
  /// When true, Workday job pages run capture → tailor → autofill pipeline from the extension.
  oneClickApply       Boolean     @default(true)
  /// Which resume profile the extension pre-selects: account default vs last picked on card.
  resumeProfilePickerMode ResumeProfilePickerMode @default(DEFAULT)
  /// When true, applied jobs move to archive 24 hours after `appliedAt`.
  autoArchiveAppliedJobs Boolean @default(true)
  termsAcceptedAt     DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  accounts         Account[]
  sessions         Session[]
  profiles         Profile[]
  apiKeys          UserApiKey[]
  usageLogs        UsageLog[]
  apiCallLogs      ApiCallLog[]
  jobTrackerEntries JobTrackerEntry[]
  jobResumeTailors  JobResumeTailor[]

  @@index([vaultKeyId])
  @@map("users")
}

enum JobTrackerStatus {
  CAPTURED
  RESUME_READY
  READY_TO_APPLY
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  ARCHIVED
}

/// Saved and applied roles — source of truth for the Job Tracker (extension + dashboard).
model JobTrackerEntry {
  id            String           @id @default(cuid())
  userId        String
  canonicalUrl  String
  urlHash       String
  title         String
  company       String?
  location      String?
  salaryText    String?
  description   String?          @db.Text
  platform      String?
  status        JobTrackerStatus @default(CAPTURED)
  savedAt       DateTime         @default(now())
  appliedAt     DateTime?
  archivedAt    DateTime?
  notes             String?          @db.Text
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeTailor      JobResumeTailor?

  @@unique([userId, urlHash])
  @@index([userId, status])
  @@index([userId, savedAt])
  @@map("job_tracker_entries")
}

/// Per-job resume deltas — merge with `sourceProfileId` at read time (no full profile clone).
model JobResumeTailor {
  id                String          @id @default(cuid())
  jobTrackerEntryId String          @unique
  userId            String
  sourceProfileId   String
  overrides         Json            @default("{}")
  changedSections   String[]        @default([])
  enhanceTraceId    String?
  coverLetter       String?         @db.Text
  resumeLatex       String?         @db.Text
  coverLetterLatex  String?         @db.Text
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  jobTrackerEntry   JobTrackerEntry @relation(fields: [jobTrackerEntryId], references: [id], onDelete: Cascade)
  sourceProfile     Profile         @relation(fields: [sourceProfileId], references: [id], onDelete: Restrict)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sourceProfileId])
  @@map("job_resume_tailors")
}

/// Server-side BYOK reference — raw keys live in Supabase Vault (`vault.secrets`).
model UserApiKey {
  id            String   @id @default(cuid())
  userId        String
  provider      String
  vaultSecretId String   @unique @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("user_api_keys")
}

/// EasySubmit system AI keys — raw secrets in Supabase Vault (`vault.secrets`).
model SystemApiKey {
  slot            Int       @id
  vaultSecretId   String    @unique @db.Uuid
  label           String?
  enabled         Boolean   @default(true)
  provider        String    @default("gemini")
  /// `free` | `paid` — slot 2 (Gamma) switches to paid overflow via hot DB update.
  billingMode     String    @default("free")
  /// Authoritative Gemini model id for this slot.
  modelId         String    @default("gemini-2.5-flash-lite")
  callsToday      Int       @default(0)
  exhaustedUntil  DateTime?
  /// Last quota reset calendar day in America/Los_Angeles (`YYYY-MM-DD`).
  quotaResetDate  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("system_api_keys")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Career resume profile — contact scalars + structured resume JSON on one row.
model Profile {
  id               String   @id @default(cuid())
  userId           String
  isDefault        Boolean  @default(false)
  firstName        String?
  lastName         String?
  email            String
  phone            String?
  city             String?
  country          String?
  targetTitle      String?
  summary          String?  @db.Text
  skills           String[] @default([])
  resumeRawText    String?  @db.Text
  /// Structured resume sections (experience, education, certifications, projects, languages, …).
  content          Json     @default("{}")
  calibrationScore Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobResumeTailors JobResumeTailor[]

  @@index([email])
  @@index([userId])
  @@index([userId, isDefault])
  @@index([targetTitle])
  @@map("profiles")
}

/// Per-request AI usage ledger for cost tracking and quota enforcement.
model UsageLog {
  id            String   @id @default(cuid())
  userId        String
  tokensUsed    Int
  modelId       String
  estimatedCost Decimal  @db.Decimal(12, 6)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("usage_logs")
}

/// Structured external API telemetry — AI provider calls, handshakes, vault ops.
model ApiCallLog {
  id            String   @id @default(cuid())
  traceId       String?
  userId        String?
  domain        String
  operation     String
  provider      String?
  modelId       String?
  status        String
  httpStatus    Int?
  durationMs    Int
  tokensUsed    Int?
  estimatedCost Decimal? @db.Decimal(12, 6)
  aiMode        String?
  keySlot       Int?
  keyLabel      String?
  keySource     String?
  billingMode   String?
  errorCode     String?
  errorMessage  String?  @db.Text
  metadata      Json?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([traceId])
  @@index([userId])
  @@index([createdAt])
  @@index([domain, operation])
  @@index([provider, status])
  @@map("api_call_logs")
}

/// Global runtime configuration keyed by logical namespace (e.g. dataRefresh, aiConfig).
model AppConfig {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_config")
}

/// Global product feature toggles — one row per flag key.
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  /// Optional per-flag JSON config (rollout hints, UI copy, limits, etc.).
  extra       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}
