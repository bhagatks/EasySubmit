generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(cuid())
  firstName        String?
  lastName         String?
  name             String?
  email            String?        @unique
  emailVerified    DateTime?
  image            String?
  onboardingStep   Int            @default(0)
  lastAuthProvider String?
  /// Pointer to `vault.secrets.id` for the active BYOK key — never store raw secrets here.
  vaultKeyId       String?        @db.Uuid
  /// Active BYOK provider (e.g. `anthropic`, `openai`, `gemini`).
  activeProvider   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  accounts         Account[]
  sessions         Session[]
  profiles         Profile[]
  apiKeys          UserApiKey[]
  usageLogs        UsageLog[]

  @@index([vaultKeyId])
  @@map("users")
}

/// Server-side BYOK reference — raw keys live in Supabase Vault (`vault.secrets`).
model UserApiKey {
  id            String   @id @default(cuid())
  userId        String
  provider      String
  vaultSecretId String   @unique @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("user_api_keys")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Career resume profile — contact scalars + structured resume JSON on one row.
model Profile {
  id               String   @id @default(cuid())
  userId           String
  isDefault        Boolean  @default(false)
  firstName        String?
  lastName         String?
  email            String
  phone            String?
  city             String?
  country          String?
  targetTitle      String?
  summary          String?  @db.Text
  skills           String[] @default([])
  resumeRawText    String?  @db.Text
  /// Structured resume sections (experience, education, certifications, projects, languages, …).
  content          Json     @default("{}")
  calibrationScore Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([userId])
  @@index([userId, isDefault])
  @@index([targetTitle])
  @@map("profiles")
}

/// Per-request AI usage ledger for cost tracking and quota enforcement.
model UsageLog {
  id            String   @id @default(cuid())
  userId        String
  tokensUsed    Int
  modelId       String
  estimatedCost Decimal  @db.Decimal(12, 6)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("usage_logs")
}

/// Global runtime configuration keyed by logical namespace (e.g. dataRefresh, aiConfig).
model AppConfig {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_config")
}
