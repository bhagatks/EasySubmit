# --- Database (LOCAL DEV — EasySubmitQA / dwccqrbpwbnuoiihpgth) ---
# Prod yofgnflcqajqsepbfdkc → Vercel Dashboard only. Repair: node scripts/repair-local-env.mjs
# Session pooler for app runtime — Supabase → Database → Connection string → Session
DATABASE_URL=postgresql://postgres.dwccqrbpwbnuoiihpgth:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session pooler for prisma migrate — Supabase → Database → Connection string → Session
DIRECT_URL=postgresql://postgres.dwccqrbpwbnuoiihpgth:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# --- NextAuth (local) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

NEXT_PUBLIC_SUPABASE_URL=https://dwccqrbpwbnuoiihpgth.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_fOoTx2gDstimYRsdaZxEyQ_bigxIja5
# (stored in Supabase Vault + `system_api_keys` table, slots 0–2). Env list is fallback when vault is empty.
EASYSUBMIT_SYSTEM_GEMINI_API_KEYS=
# Optional client Enhance with AI wait (ms). DB `app_config.enhanceWithAi` takes precedence when seeded.
EASYSUBMIT_ENHANCE_WITH_AI_TIMEOUT_MS=90000
# Deprecated — use `app_config.aiEngine.system.modelId` instead. Env override still honored in code fallback.
EASYSUBMIT_SYSTEM_GEMINI_MODEL=gemini-2.5-flash-lite

# --- Supabase (Vault + Job Tracker Realtime) ---
# URL + publishable/anon key: Supabase Dashboard → Settings → API Keys
# NEXT_PUBLIC_SUPABASE_URL and DATABASE_URL are set above (dev project dwccqrbpwbnuoiihpgth)
# Fallback if not using publishable key:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Realtime JWT signing secret: Settings → JWT Keys (legacy JWT secret). Required for useJobTrackerSync Realtime.
SUPABASE_JWT_SECRET=
# After setting env, run once: scripts/sql/job-tracker-realtime-setup.sql in Supabase SQL Editor

# --- Analytics (PostHog) — dev project 488025 ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_ANALYTICS_ENV=dev
# Personal API key (phx_...) — required for `npm run posthog:journey` to read events from PostHog
POSTHOG_PERSONAL_API_KEY=
POSTHOG_DEV_PROJECT_ID=488025
POSTHOG_PROD_PROJECT_ID=488042
# Optional: comma-separated user ids to tag as internal in PostHog
NEXT_PUBLIC_ANALYTICS_INTERNAL_USER_IDS=

# Web autocapture (clicks/forms) — on for dashboard; extension build forces false
NEXT_PUBLIC_POSTHOG_AUTOCAPTURE=true

# Server logging (Pino) — debug locally, info in prod
LOG_LEVEL=debug
