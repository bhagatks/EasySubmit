# Supabase (Auth + Storage)
# Environment-specific values — see:
#   .env.qa.example   → QA  (dwccqrbpwbnuoiihpgth)
#   .env.prod.example → Prod (yofgnflcqajqsepbfdkc)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# NextAuth (OAuth login at /login)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# PostgreSQL (Supabase connection string for Prisma)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Production (Vercel) ---
# Set NEXTAUTH_URL to your deployed origin, e.g. https://your-app.vercel.app
# OAuth redirect URIs must include:
#   https://<domain>/api/auth/callback/google
#   https://<domain>/api/auth/callback/linkedin
