# LOCAL DEV ONLY — system Gemini keys. Production: vault via `npm run db:import-system-keys`
# (stored in Supabase Vault + `system_api_keys` table, slots 0–2). Env list is fallback when vault is empty.
EASYSUBMIT_SYSTEM_GEMINI_API_KEYS=
# Optional client Enhance with AI wait (ms). DB `app_config.enhanceWithAi` takes precedence when seeded.
EASYSUBMIT_ENHANCE_WITH_AI_TIMEOUT_MS=90000
# Deprecated — use `app_config.aiEngine.system.modelId` instead. Env override still honored in code fallback.
EASYSUBMIT_SYSTEM_GEMINI_MODEL=gemini-2.5-flash-lite

# --- Supabase (Vault + Job Tracker Realtime) ---
# URL + publishable/anon key: Supabase Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Fallback if not using publishable key:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Realtime JWT signing secret: Settings → JWT Keys (legacy JWT secret). Required for useJobTrackerSync Realtime.
SUPABASE_JWT_SECRET=
# After setting env, run once: scripts/sql/job-tracker-realtime-setup.sql in Supabase SQL Editor
