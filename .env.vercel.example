# Do NOT copy to .env.local — set once in Vercel; redeploy only when a value changes.

NEXT_PUBLIC_SUPABASE_URL=https://yofgnflcqajqsepbfdkc.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_jB3660sY4WeZ5Ru4Dp1kMA_F7XAw56g

NEXTAUTH_URL=https://www.easysubmit.ai
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# App runtime — Supabase → Database → URI → Transaction pooler (:6543)
DATABASE_URL=postgresql://postgres.yofgnflcqajqsepbfdkc:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Migrations on Vercel build — Session pooler (:5432), same password as DATABASE_URL.
# Prefer this host (worked on Vercel); db.*.supabase.co:5432 can fail with P1001 from some networks.
DIRECT_URL=postgresql://postgres.yofgnflcqajqsepbfdkc:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Required for avatar upload (Supabase → Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Analytics — prod PostHog project 488042
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_ANALYTICS_ENV=prod
NEXT_PUBLIC_ANALYTICS_INTERNAL_USER_IDS=
NEXT_PUBLIC_POSTHOG_AUTOCAPTURE=true
LOG_LEVEL=info

# O*NET Web Services v2 — Role Skills Framework (enhance pipeline pre_role_vocab)
